# always — modules that always return a given code

always reject {
    rcode = reject
}

always fail {
    rcode = fail
}

always ok {
    rcode = ok
    simulcount = 0
    mpp = no
}

always handled {
    rcode = handled
}

always invalid {
    rcode = invalid
}

always userlock {
    rcode = userlock
}

always notfound {
    rcode = notfound
}

always noop {
    rcode = noop
}

always updated {
    rcode = updated
}
