# FadilJaya.NET — attr_filter module
# Filters attributes on Access-Accept and Accounting packets.

attr_filter attr_filter.access_reject {
    key     = "%{User-Name}"
    filename = ${modconfdir}/attr_filter/access_reject
}

attr_filter attr_filter.access_challenge {
    key     = "%{User-Name}"
    filename = ${modconfdir}/attr_filter/access_challenge
}

attr_filter attr_filter.pre_proxy {
    key     = "%{Realm}"
    filename = ${modconfdir}/attr_filter/pre_proxy
}

attr_filter attr_filter.post_proxy {
    key     = "%{Realm}"
    filename = ${modconfdir}/attr_filter/post_proxy
}

attr_filter attr_filter.accounting_response {
    key     = "%{User-Name}"
    filename = ${modconfdir}/attr_filter/accounting_response
}
